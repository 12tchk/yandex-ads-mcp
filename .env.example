# Yandex Direct API (required). Prefer the separate 600-permission token file.
# Get OAuth token: https://oauth.yandex.ru/authorize?response_type=token&client_id=YOUR_CLIENT_ID
# Required scopes: direct:api
YD_OAUTH_TOKEN=
YD_OAUTH_TOKEN_FILE=/secure/path/yandex-direct.token

# Yandex Cloud (required for Wordstat API)
# Get folder ID from https://console.yandex.cloud/
# Required: billing account + role search-api.executor on folder
# OAuth token must have scope cloud:auth
YC_FOLDER_ID=YOUR_FOLDER_ID_HERE

# Optional
YD_SANDBOX=false
YD_LOGIN=

# ── Safety / access control (12tchk fork) ──────────────────────────────
# Safe defaults: write tools are hidden and rejected.
YD_READONLY=true
# A second independent switch. Keep false for every read-only deployment.
YD_WRITE_ARMED=false
# Mandatory if write access is deliberately armed in a future controlled rollout.
YD_CONFIRM=true
# Require an explicit Client-Login on every Direct call.
YD_REQUIRE_LOGIN_ALLOWLIST=true
# Exact agency Client-Logins, comma-separated. Production Direct access will not start empty.
YD_ALLOWED_LOGINS=required-client-login
# Exact server-side tool allowlist. Empty exposes nothing.
YD_ENABLED_TOOLS=yd_campaigns_get,yd_adgroups_get,yd_ads_get,yd_keywords_get,yd_keyword_bids_get,yd_bid_modifiers_get,yd_excluded_sites_get,yd_negative_keywords_sets_get,yd_changes_check,yd_report
# Never enable this in production. It is rejected outside YD_SANDBOX=true.
YD_ALLOW_ALL_TOOLS=false

# ── Logging (fork additions) ───────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default INFO).
YD_LOG_LEVEL=INFO
# Path to a log file. Empty = stderr only, no file on disk (previous builds always wrote one).
YD_LOG_FILE=
# Dump full request/response bodies to the log (verbose; may contain ad/campaign data).
YD_LOG_BODIES=false
