# Yandex Direct API (required)
# Get OAuth token: https://oauth.yandex.ru/authorize?response_type=token&client_id=YOUR_CLIENT_ID
# Required scopes: direct:api
YD_OAUTH_TOKEN=y0_YOUR_TOKEN_HERE

# Yandex Cloud (required for Wordstat API)
# Get folder ID from https://console.yandex.cloud/
# Required: billing account + role search-api.executor on folder
# OAuth token must have scope cloud:auth
YC_FOLDER_ID=YOUR_FOLDER_ID_HERE

# Optional
YD_SANDBOX=false
YD_LOGIN=

# ── Safety / access control (fork additions) ───────────────────────────
# Block every mutating tool (add/update/delete/action/set/...). Reports & reads still work.
YD_READONLY=false
# Require confirm=true on every mutating tool; otherwise the call returns a preview only.
YD_CONFIRM=false
# Whitelist of allowed agency Client-Logins (comma-separated). Empty = no restriction.
# Applies to Yandex Direct tools; per-call override via the client_login argument.
YD_ALLOWED_LOGINS=

# ── Logging (fork additions) ───────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default INFO).
YD_LOG_LEVEL=INFO
# Path to a log file. Empty = stderr only, no file on disk (previous builds always wrote one).
YD_LOG_FILE=
# Dump full request/response bodies to the log (verbose; may contain ad/campaign data).
YD_LOG_BODIES=false
