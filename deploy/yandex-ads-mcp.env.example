# Store the token itself in this separate file and restrict it to the service user (chmod 600).
YD_OAUTH_TOKEN_FILE=/secure/path/yandex-direct.token
YD_OAUTH_TOKEN=

# Exact client accounts available to this Codex MCP deployment.
YD_ALLOWED_LOGINS=client-login-1,client-login-2

# Direct read surface for the first production pilot.
YD_ENABLED_TOOLS=yd_campaigns_get,yd_adgroups_get,yd_ads_get,yd_keywords_get,yd_keyword_bids_get,yd_bid_modifiers_get,yd_excluded_sites_get,yd_negative_keywords_sets_get,yd_changes_check,yd_report

YD_SANDBOX=false
YD_LOGIN=
YD_LOG_LEVEL=WARNING
YD_LOG_FILE=

# Forced again by deploy/run-readonly.sh; kept explicit for audits.
YD_READONLY=true
YD_WRITE_ARMED=false
YD_CONFIRM=true
YD_REQUIRE_LOGIN_ALLOWLIST=true
YD_ALLOW_ALL_TOOLS=false
YD_LOG_BODIES=false
